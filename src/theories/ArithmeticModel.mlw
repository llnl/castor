	let function or_s16 (a b : int) : int = BV16.to_int  (BV16.bw_or (BV16.of_int (to_uint16 a)) (BV16.of_int (to_uint16 b)))
	let function or_s32 (a b : int) : int = BV32.to_int  (BV32.bw_or (BV32.of_int (to_uint32 a)) (BV32.of_int (to_uint32 b)))
