	lemma neg_u32_alt_def: forall x:int [neg_u32 x]. is_uint32 x -> (neg_u32 x = max_uint32 - x - 1 by
		BV32.t'int (BV32.bw_not (BV32.of_int x)) = 4294967295 - x by
		BV32.bw_not (BV32.of_int x) = BV32.sub (4294967295 : BV32.t) (BV32.of_int x) by
		BV32.of_int x = BV32.of_int (to_uint32 x))
	lemma neg_u64_alt_def: forall x:int [neg_u64 x]. is_uint32 x -> (neg_u64 x = max_uint64 - x - 1 by
		BV64.t'int (BV64.bw_not (BV64.of_int x)) = 18446744073709551615 - x by
		BV64.bw_not (BV64.of_int x) = BV64.sub (18446744073709551615 : BV64.t) (BV64.of_int x) by
		BV64.of_int x = BV64.of_int (to_uint64 x))
