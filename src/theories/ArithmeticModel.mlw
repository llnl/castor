theory ArithmeticModel
	use int.Int
	use int.Abs
	use int.ComputerDivision
	use int.EuclideanDivision
	use bv.Pow2int
	use bv.BV8
	use bv.BV16
	use bv.BV32
	use bv.BV64

	let function (/) (a : int) (b : int) : int
	requires { [@expl:Not dividing by 0] b <> 0 }
	ensures { result = ComputerDivision.div a b }
	= ComputerDivision.div a b

	let function max_uint8: int = 256
	let function max_sint8: int = 128
	let function max_uint16: int = 65536
	let function max_sint16: int = 32768
	let function max_uint32: int = 4294967296
	let function max_sint32: int = 2147483648
	let function max_uint64: int = 18446744073709551616
	let function max_sint64: int = 9223372036854775808

	predicate is_uint8 (x : int)  = 0 <= x < max_uint8
	predicate is_sint8 (x : int)  = -max_sint8 <= x < max_sint8
	predicate is_uint16 (x : int) = 0 <= x < max_uint16
	predicate is_sint16 (x : int) = -max_sint16 <= x < max_sint16
	predicate is_uint32 (x : int) = 0 <= x < max_uint32
	predicate is_sint32 (x : int) = -max_sint32 <= x < max_sint32
	predicate is_uint64 (x : int) = 0 <= x < max_uint64
	predicate is_sint64 (x : int) = -max_sint64 <= x < max_sint64

	let rec function to_uint8  (x : int)
	variant { if x < 0 then abs(x) + max_uint8 else x }
	ensures { is_uint8 result }
	= if x < 0 then to_uint8 (x + max_uint8) else if x >= max_uint8 then to_uint8 (x - max_uint8) else x

	val function to_sint8  int : int

	let rec function to_uint16 (x : int)
	variant { if x < 0 then abs(x) + max_uint16 else x }
	ensures { is_uint16 result }
	= if x < 0 then to_uint16 (x + max_uint16) else if x >= max_uint16 then to_uint16 (x - max_uint16) else x

	val function to_sint16 int : int

	let rec function to_uint32 (x : int) variant { if x < 0 then abs(x) + max_uint32 else x }
	ensures { is_uint32 result }
	= if x < 0 then to_uint32 (x + max_uint32) else if x >= max_uint32 then to_uint32 (x - max_uint32) else x

	val function to_sint32 int : int

	let rec function to_uint64 (x : int)
	variant { if x < 0 then abs(x) + max_uint64 else x }
	ensures { is_uint64 result }
	= if x < 0 then to_uint64 (x + max_uint64) else if x >= max_uint64 then to_uint64 (x - max_uint64) else x

	val function to_sint64 int : int

	lemma is_to_uint8  : forall x:int. is_uint8  (to_uint8 x)
	axiom is_to_sint8  : forall x:int. is_sint8  (to_sint8 x)
	lemma is_to_uint16 : forall x:int. is_uint16 (to_uint16 x)
	axiom is_to_sint16 : forall x:int. is_sint16 (to_sint16 x)
	lemma is_to_uint32 : forall x:int. is_uint32 (to_uint32 x)
	axiom is_to_sint32 : forall x:int. is_sint32 (to_sint32 x)
	lemma is_to_uint64 : forall x:int. is_uint64 (to_uint64 x)
	axiom is_to_sint64 : forall x:int. is_sint64 (to_sint64 x)
	meta "remove_unused:dependency" lemma is_to_uint8,  function to_uint8
	meta "remove_unused:dependency" lemma is_to_uint16, function to_uint16
	meta "remove_unused:dependency" lemma is_to_uint32, function to_uint32
	meta "remove_unused:dependency" lemma is_to_uint64, function to_uint64
	meta "remove_unused:dependency" axiom is_to_sint8,  function to_sint8
	meta "remove_unused:dependency" axiom is_to_sint16, function to_sint16
	meta "remove_unused:dependency" axiom is_to_sint32, function to_sint32
	meta "remove_unused:dependency" axiom is_to_sint64, function to_sint64

	lemma id_uint8  : forall x:int [ to_uint8 x ].  is_uint8 x  -> (to_uint8 x)  = x
	axiom id_sint8  : forall x:int [ to_sint8 x ].  is_sint8 x  -> (to_sint8 x)  = x
	lemma id_uint16 : forall x:int [ to_uint16 x ]. is_uint16 x -> (to_uint16 x) = x
	axiom id_sint16 : forall x:int [ to_sint16 x ]. is_sint16 x -> (to_sint16 x) = x
	lemma id_uint32 : forall x:int [ to_uint32 x ]. is_uint32 x -> (to_uint32 x) = x
	axiom id_sint32 : forall x:int [ to_sint32 x ]. is_sint32 x -> (to_sint32 x) = x
	lemma id_uint64 : forall x:int [ to_uint64 x ]. is_uint64 x -> (to_uint64 x) = x
	axiom id_sint64 : forall x:int [ to_sint64 x ]. is_sint64 x -> (to_sint64 x) = x
	meta "remove_unused:dependency" lemma id_uint8,  function to_uint8
	meta "remove_unused:dependency" lemma id_uint16, function to_uint16
	meta "remove_unused:dependency" lemma id_uint32, function to_uint32
	meta "remove_unused:dependency" lemma id_uint64, function to_uint64
	meta "remove_unused:dependency" axiom id_sint8,  function to_sint8
	meta "remove_unused:dependency" axiom id_sint16, function to_sint16
	meta "remove_unused:dependency" axiom id_sint32, function to_sint32
	meta "remove_unused:dependency" axiom id_sint64, function to_sint64

	lemma proj_uint8  : forall x:int [ to_uint8  (to_uint8  x) ]. to_uint8  (to_uint8  x) = to_uint8  x
	lemma proj_sint8  : forall x:int [ to_sint8  (to_sint8  x) ]. to_sint8  (to_sint8  x) = to_sint8  x
	lemma proj_uint16 : forall x:int [ to_uint16 (to_uint16 x) ]. to_uint16 (to_uint16 x) = to_uint16 x
	lemma proj_sint16 : forall x:int [ to_sint16 (to_sint16 x) ]. to_sint16 (to_sint16 x) = to_sint16 x
	lemma proj_uint32 : forall x:int [ to_uint32 (to_uint32 x) ]. to_uint32 (to_uint32 x) = to_uint32 x
	lemma proj_sint32 : forall x:int [ to_sint32 (to_sint32 x) ]. to_sint32 (to_sint32 x) = to_sint32 x
	lemma proj_uint64 : forall x:int [ to_uint64 (to_uint64 x) ]. to_uint64 (to_uint64 x) = to_uint64 x
	lemma proj_sint64 : forall x:int [ to_sint64 (to_sint64 x) ]. to_sint64 (to_sint64 x) = to_sint64 x
	meta "remove_unused:dependency" lemma proj_uint8,  function to_uint8
	meta "remove_unused:dependency" lemma proj_uint16, function to_uint16
	meta "remove_unused:dependency" lemma proj_uint32, function to_uint32
	meta "remove_unused:dependency" lemma proj_uint64, function to_uint64
	meta "remove_unused:dependency" lemma proj_sint8,  function to_sint8
	meta "remove_unused:dependency" lemma proj_sint16, function to_sint16
	meta "remove_unused:dependency" lemma proj_sint32, function to_sint32
	meta "remove_unused:dependency" lemma proj_sint64, function to_sint64

	lemma uint8_upcast_1:  forall x:int. is_uint8 x  -> to_uint16 x = x
	lemma uint8_upcast_2:  forall x:int. is_uint8 x  -> to_sint16 x = x
	lemma uint8_upcast_3:  forall x:int. is_uint8 x  -> to_uint32 x = x
	lemma uint8_upcast_4:  forall x:int. is_uint8 x  -> to_sint32 x = x
	lemma uint8_upcast_5:  forall x:int. is_uint8 x  -> to_uint64 x = x
	lemma uint8_upcast_6:  forall x:int. is_uint8 x  -> to_sint64 x = x
	meta "remove_unused:dependency" lemma uint8_upcast_1, function to_uint16
	meta "remove_unused:dependency" lemma uint8_upcast_2, function to_sint16
	meta "remove_unused:dependency" lemma uint8_upcast_3, function to_uint32
	meta "remove_unused:dependency" lemma uint8_upcast_4, function to_sint32
	meta "remove_unused:dependency" lemma uint8_upcast_5, function to_uint64
	meta "remove_unused:dependency" lemma uint8_upcast_6, function to_sint64

	lemma sint8_upcast_1:  forall x:int. is_sint8 x  -> to_sint16 x = x
	lemma sint8_upcast_2:  forall x:int. is_sint8 x  -> to_sint32 x = x
	lemma sint8_upcast_3:  forall x:int. is_sint8 x  -> to_sint64 x = x
	meta "remove_unused:dependency" lemma sint8_upcast_1, function to_sint16
	meta "remove_unused:dependency" lemma sint8_upcast_2, function to_sint32
	meta "remove_unused:dependency" lemma sint8_upcast_3, function to_sint64

	lemma uint16_upcast_1: forall x:int. is_uint16 x -> to_uint32 x = x
	lemma uint16_upcast_2: forall x:int. is_uint16 x -> to_sint32 x = x
	lemma uint16_upcast_3: forall x:int. is_uint16 x -> to_uint64 x = x
	lemma uint16_upcast_4: forall x:int. is_uint16 x -> to_sint64 x = x
	meta "remove_unused:dependency" lemma uint16_upcast_1, function to_uint32
	meta "remove_unused:dependency" lemma uint16_upcast_2, function to_sint32
	meta "remove_unused:dependency" lemma uint16_upcast_3, function to_uint64
	meta "remove_unused:dependency" lemma uint16_upcast_4, function to_sint64

	lemma sint16_upcast_1: forall x:int. is_sint16 x -> to_sint32 x = x
	lemma sint16_upcast_2: forall x:int. is_sint16 x -> to_sint64 x = x
	meta "remove_unused:dependency" lemma sint16_upcast_1, function to_sint32
	meta "remove_unused:dependency" lemma sint16_upcast_2, function to_sint64

	lemma uint32_upcast_1: forall x:int. is_uint32 x -> to_uint64 x = x
	lemma uint32_upcast_2: forall x:int. is_uint32 x -> to_sint64 x = x
	meta "remove_unused:dependency" lemma uint32_upcast_1, function to_uint64
	meta "remove_unused:dependency" lemma uint32_upcast_2, function to_sint64

	lemma sint32_upcast_1: forall x:int. is_sint32 x -> to_sint64 x = x
	meta "remove_unused:dependency" lemma sint32_upcast_1, function to_sint64

	let lemma uint8_downcast (x : int)
	ensures { to_uint8 x = EuclideanDivision.mod x max_uint8 }
	=
		let to_result = to_uint8 x in
		let ref prog_result = x in
		while not is_uint8 prog_result do
			invariant { to_uint8 prog_result = to_result }
			invariant { exists mul:int. prog_result + mul * max_uint8 = x }
			variant { if prog_result < 0 then abs(prog_result) + max_uint8 else prog_result }
			if prog_result < 0
				then prog_result <- prog_result + max_uint8
				else prog_result <- prog_result - max_uint8
		done;
		assert { prog_result = to_result };
		assert { prog_result = EuclideanDivision.mod x max_uint8 }

	let lemma uint16_downcast (x : int)
	ensures { to_uint16 x = EuclideanDivision.mod x max_uint16 }
	=
		let to_result = to_uint16 x in
		let ref prog_result = x in
		while not is_uint16 prog_result do
			invariant { to_uint16 prog_result = to_result }
			invariant { exists mul:int. prog_result + mul * max_uint16 = x }
			variant { if prog_result < 0 then abs(prog_result) + max_uint16 else prog_result }
			if prog_result < 0
				then prog_result <- prog_result + max_uint16
				else prog_result <- prog_result - max_uint16
		done;
		assert { prog_result = to_result };
		assert { prog_result = EuclideanDivision.mod x max_uint16 }

	let lemma uint32_downcast (x : int)
	ensures { to_uint32 x = EuclideanDivision.mod x max_uint32 }
	=
		let to_result = to_uint32 x in
		let ref prog_result = x in
		while not is_uint32 prog_result do
			invariant { to_uint32 prog_result = to_result }
			invariant { exists mul:int. prog_result + mul * max_uint32 = x }
			variant { if prog_result < 0 then abs(prog_result) + max_uint32 else prog_result }
			if prog_result < 0
				then prog_result <- prog_result + max_uint32
				else prog_result <- prog_result - max_uint32
		done;
		assert { prog_result = to_result };
		assert { prog_result = EuclideanDivision.mod x max_uint32 }

	let lemma uint64_downcast (x : int)
	ensures { to_uint64 x = EuclideanDivision.mod x max_uint64 }
	=
		let to_result = to_uint64 x in
		let ref prog_result = x in
		while not is_uint64 prog_result do
			invariant { to_uint64 prog_result = to_result }
			invariant { exists mul:int. prog_result + mul * max_uint64 = x }
			variant { if prog_result < 0 then abs(prog_result) + max_uint64 else prog_result }
			if prog_result < 0
				then prog_result <- prog_result + max_uint64
				else prog_result <- prog_result - max_uint64
		done;
		assert { prog_result = to_result };
		assert { prog_result = EuclideanDivision.mod x max_uint64 }

	let function and_s8  (a b : int) : int = BV8.to_int   (BV8.bw_and  (BV8.of_int  (to_uint8  a)) (BV8.of_int  (to_uint8  b)))
	let function and_s16 (a b : int) : int = BV16.to_int  (BV16.bw_and (BV16.of_int (to_uint16 a)) (BV16.of_int (to_uint16 b)))
	let function and_s32 (a b : int) : int = BV32.to_int  (BV32.bw_and (BV32.of_int (to_uint32 a)) (BV32.of_int (to_uint32 b)))
	let function and_s64 (a b : int) : int = BV64.to_int  (BV64.bw_and (BV64.of_int (to_uint64 a)) (BV64.of_int (to_uint64 b)))
	let function and_u8  (a b : int) : int = BV8.to_uint  (BV8.bw_and  (BV8.of_int  (to_uint8  a)) (BV8.of_int  (to_uint8  b)))
	let function and_u16 (a b : int) : int = BV16.to_uint (BV16.bw_and (BV16.of_int (to_uint16 a)) (BV16.of_int (to_uint16 b)))
	let function and_u32 (a b : int) : int = BV32.to_uint (BV32.bw_and (BV32.of_int (to_uint32 a)) (BV32.of_int (to_uint32 b)))
	let function and_u64 (a b : int) : int = BV64.to_uint (BV64.bw_and (BV64.of_int (to_uint64 a)) (BV64.of_int (to_uint64 b)))

