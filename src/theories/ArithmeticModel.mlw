	let function lsl_s8  (a b : int) : int = BV8.to_int   (BV8.lsl_bv  (BV8.of_int  (to_uint8  a)) (BV8.of_int  (to_uint8  b)))
	let function lsl_s16 (a b : int) : int = BV16.to_int  (BV16.lsl_bv (BV16.of_int (to_uint16 a)) (BV16.of_int (to_uint16 b)))
	let function lsl_s32 (a b : int) : int = BV32.to_int  (BV32.lsl_bv (BV32.of_int (to_uint32 a)) (BV32.of_int (to_uint32 b)))
