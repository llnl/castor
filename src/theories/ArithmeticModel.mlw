	let function div_s8  (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_sint8  (a / b)
	let function div_s16 (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_sint16 (a / b)
	let function div_s32 (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_sint32 (a / b)
	let function div_s64 (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_sint64 (a / b)
	let function div_u8  (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_uint8  (a / b)
	let function div_u16 (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_uint16 (a / b)
	let function div_u32 (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_uint32 (a / b)
	let function div_u64 (a b : int) : int requires { [@expl:Not dividing by 0] b <> 0 } = to_uint64 (a / b)

	lemma div_sint8_is_div:  forall x:int, y:int. y <> 0 -> (is_sint8  (x / y) <-> div_s8  x y = x / y)
	lemma div_sint16_is_div: forall x:int, y:int. y <> 0 -> (is_sint16 (x / y) <-> div_s16 x y = x / y)
	lemma div_sint32_is_div: forall x:int, y:int. y <> 0 -> (is_sint32 (x / y) <-> div_s32 x y = x / y)
	lemma div_sint64_is_div: forall x:int, y:int. y <> 0 -> (is_sint64 (x / y) <-> div_s64 x y = x / y)
	lemma div_uint8_is_div:  forall x:int, y:int. y <> 0 -> (is_uint8  (x / y) <-> div_u8  x y = x / y)
	lemma div_uint16_is_div: forall x:int, y:int. y <> 0 -> (is_uint16 (x / y) <-> div_u16 x y = x / y)
	lemma div_uint32_is_div: forall x:int, y:int. y <> 0 -> (is_uint32 (x / y) <-> div_u32 x y = x / y)
	lemma div_uint64_is_div: forall x:int, y:int. y <> 0 -> (is_uint64 (x / y) <-> div_u64 x y = x / y)
