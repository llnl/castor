	lemma div_sint8_is_div_2:  forall x:int, y:int. is_sint8  x /\ y <> 0 /\ y <> -1 -> div_s8  x y = x / y
	lemma div_sint16_is_div_2: forall x:int, y:int. is_sint16 x /\ y <> 0 /\ y <> -1 -> div_s16 x y = x / y
	lemma div_sint32_is_div_2: forall x:int, y:int. is_sint32 x /\ y <> 0 /\ y <> -1 -> div_s32 x y = x / y
	lemma div_sint64_is_div_2: forall x:int, y:int. is_sint64 x /\ y <> 0 /\ y <> -1 -> div_s64 x y = x / y
	lemma div_uint8_is_div_2:  forall x:int, y:int. is_uint8  x /\ y > 0 -> div_u8  x y = x / y
	lemma div_uint16_is_div_2: forall x:int, y:int. is_uint16 x /\ y > 0 -> div_u16 x y = x / y
	lemma div_uint32_is_div_2: forall x:int, y:int. is_uint32 x /\ y > 0 -> div_u32 x y = x / y
	lemma div_uint64_is_div_2: forall x:int, y:int. is_uint64 x /\ y > 0 -> div_u64 x y = x / y
