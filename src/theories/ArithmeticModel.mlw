	let function bool_2_var (a : bool) : int = if a then 1 else 0
	let function var_2_bool (a : int) : bool = a <> 0

	lemma bool_2_var_truthy: bool_2_var(true) = 1
	lemma bool_2_var_falsey: bool_2_var(false) = 0
	lemma var_2_bool_truthy: forall i:int. i <> 0 -> var_2_bool(i)
	lemma var_2_bool_falsey: not var_2_bool(0)
	meta "remove_unused:dependency" lemma bool_2_var_truthy, function bool_2_var
	meta "remove_unused:dependency" lemma bool_2_var_falsey, function bool_2_var
	meta "remove_unused:dependency" lemma var_2_bool_truthy, function var_2_bool
	meta "remove_unused:dependency" lemma var_2_bool_falsey, function var_2_bool

	let function arbitrary (x : int) : int
	ensures { result >= x }
	=
		any int ensures { result >= x }
end

