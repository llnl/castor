	lemma mod_div_relation_sint8:  forall x:int, y:int. is_sint8  x /\ is_sint8  y /\ y <> 0 /\ y <> -1 -> mul_s8  (div_s8  x y) y + mod_s8  x y = x
	lemma mod_div_relation_sint16: forall x:int, y:int. is_sint16 x /\ is_sint16 y /\ y <> 0 /\ y <> -1 -> mul_s16 (div_s16 x y) y + mod_s16 x y = x
	lemma mod_div_relation_sint32: forall x:int, y:int. is_sint32 x /\ is_sint32 y /\ y <> 0 /\ y <> -1 -> mul_s32 (div_s32 x y) y + mod_s32 x y = x
	lemma mod_div_relation_sint64: forall x:int, y:int. is_sint64 x /\ is_sint64 y /\ y <> 0 /\ y <> -1 -> mul_s64 (div_s64 x y) y + mod_s64 x y = x
	lemma mod_div_relation_uint8:  forall x:int, y:int. is_uint8  x /\ is_uint8  y /\ y <> 0 /\ y <> -1 -> mul_u8  (div_u8  x y) y + mod_u8  x y = x
	lemma mod_div_relation_uint16: forall x:int, y:int. is_uint16 x /\ is_uint16 y /\ y <> 0 /\ y <> -1 -> mul_u16 (div_u16 x y) y + mod_u16 x y = x
	lemma mod_div_relation_uint32: forall x:int, y:int. is_uint32 x /\ is_uint32 y /\ y <> 0 /\ y <> -1 -> mul_u32 (div_u32 x y) y + mod_u32 x y = x
	lemma mod_div_relation_uint64: forall x:int, y:int. is_uint64 x /\ is_uint64 y /\ y <> 0 /\ y <> -1 -> mul_u64 (div_u64 x y) y + mod_u64 x y = x
