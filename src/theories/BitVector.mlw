	meta "remove_unused:dependency" lemma nth_lsl_u16, function lsl_u16
	meta "remove_unused:dependency" lemma nth_lsl_u32, function lsl_u32
	meta "remove_unused:dependency" lemma nth_lsl_u64, function lsl_u64

	lemma nth_lsr_u8:  forall x:int, y:int, i:int. 0 < y < 8  /\ y <= i < 8  -> (ArithmeticModel.nth_8  x i <-> ArithmeticModel.nth_8  (ArithmeticModel.lsr_u8  x y) (i - y))
	lemma nth_lsr_u16: forall x:int, y:int, i:int. 0 < y < 16 /\ y <= i < 16 -> (ArithmeticModel.nth_16 x i <-> ArithmeticModel.nth_16 (ArithmeticModel.lsr_u16 x y) (i - y))
	lemma nth_lsr_u32: forall x:int, y:int, i:int. 0 < y < 32 /\ y <= i < 32 -> (ArithmeticModel.nth_32 x i <-> ArithmeticModel.nth_32 (ArithmeticModel.lsr_u32 x y) (i - y))
